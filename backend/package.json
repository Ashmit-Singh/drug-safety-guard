    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "fresh": "^0.5.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "opossum": "^8.1.3",
    "rate-limit-redis": "^4.2.0",
