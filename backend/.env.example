# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Drug Interaction API — Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Server
NODE_ENV=development
PORT=3000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
JWT_SECRET=your-supabase-jwt-secret

# Cassandra
CASSANDRA_HOSTS=127.0.0.1
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=drug_interaction_analytics
CASSANDRA_DATACENTER=dc1
CASSANDRA_USERNAME=
CASSANDRA_PASSWORD=

# Redis
REDIS_URL=redis://127.0.0.1:6379
REDIS_PASSWORD=

# CORS
FLUTTER_WEB_ORIGIN=http://localhost:8080

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
INTERACTION_CHECK_RATE_LIMIT_MAX=10
